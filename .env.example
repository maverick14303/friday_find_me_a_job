# ── One secret protects the run / reply / health endpoints ──
# Used in the dashboard and in your cron-job.org URLs (?secret=...).
APP_SECRET=choose-one-long-random-password

# ── Gmail delivery + reply reading (one app password does both) ──
# Uses SMTP to send and IMAP to read your replies. Requires a Gmail
# App Password, which needs 2-Step Verification ON for this account:
#   Google Account -> Security -> 2-Step Verification -> App passwords.
GMAIL_USER=your-sender-gmail@gmail.com
GMAIL_APP_PASSWORD=your-16-character-app-password
TO_EMAIL=your-personal-email@gmail.com

# ── Resume data (keeps personal data out of the repo) ──
# In production, paste your resume-profile.json (single line) here.
# Locally you can instead just create data/resume-profile.json.
# RESUME_PROFILE_JSON={"name":"...","email":"...", ...}

# ── History: never-repeat-a-company, reply-to-apply, run status ──
# Without these, those features are skipped and the daily email still works.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-publishable-key

# ── Optional recruiter-email enrichment (reply-to-apply only) ──
# Tried in order Hunter -> Apollo -> Lusha (whichever keys are set).
# Hunter has a free tier (50/mo): https://hunter.io -> Dashboard -> API.
# HUNTER_API_KEY=your-hunter-api-key
# Apollo/Lusha API access is effectively paid-only.
# APOLLO_API_KEY=your-apollo-api-key
# LUSHA_API_KEY=your-lusha-api-key
