# Secret used by the dashboard and cron-job.org URL
RUN_NOW_SECRET=choose-a-long-random-password
CRON_SECRET=choose-a-long-random-password

# Gmail delivery with Google Sign-in. Do not use the normal Gmail password.
GMAIL_USER=your-new-sender-gmail@gmail.com
TO_EMAIL=your-personal-email@gmail.com
GMAIL_OAUTH_CLIENT_ID=your-google-oauth-client-id
GMAIL_OAUTH_CLIENT_SECRET=your-google-oauth-client-secret
GMAIL_OAUTH_REDIRECT_URI=https://YOUR-VERCEL-APP.vercel.app/api/gmail-callback
# Required: must be a DIFFERENT value from RUN_NOW_SECRET/CRON_SECRET above.
# gmail-start and gmail-callback refuse to run without this set.
GMAIL_OAUTH_STATE=choose-another-long-random-password
GMAIL_OAUTH_REFRESH_TOKEN=created-after-you-click-connect-gmail

# Optional fallback only if App Password becomes available later.
# GMAIL_APP_PASSWORD=your-16-character-google-app-password

# Optional: remembers which companies were already emailed (so the same
# company is never sent twice) and powers reply-to-apply. Without these,
# both features are skipped.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-publishable-key

# Optional: paid recruiter-email enrichment, used only at reply-to-apply
# time when a job posting has no recruiter email. Apollo is tried first,
# Lusha is the fallback. Each email reveal spends provider credits.
# APOLLO_API_KEY=your-apollo-api-key
# LUSHA_API_KEY=your-lusha-api-key
